{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nooto",
  "version": "0.1.0",
  "identifier": "com.nooto.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nooto",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Encrypted notes with sync",
    "longDescription": "Nooto is a privacy-first notes application with end-to-end encryption and optional self-hosted sync.",
    "category": "Productivity",
    "copyright": "© 2026 Clément Pera",
    "linux": {
      "deb": {},
      "rpm": {},
      "appimage": {}
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
